{
  "manifest_version": 3,
  "name": "Strange TTS Solution 1.0.0",
  "version": "52.2.3",
  "description": "Strange TTS Solution — TikTok Shop Intelligence 1.0.0",
  "homepage_url": "https://drilling-beverly-reform-optimization.trycloudflare.com/",
  "privacy_policy": "https://drilling-beverly-reform-optimization.trycloudflare.com/privacy-policy-strangetts-gmv.html",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "pages/login.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "Strange TTS Solution 1.0.0"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "cookies",
    "contextMenus",
    "alarms",
    "offscreen",
    "activeTab",
    "downloads",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://seller-vn.tiktok.com/*",
    "https://seller.tiktok.com/*",
    "https://ads.tiktok.com/*",
    "https://business.tiktok.com/*",
    "https://shop.tiktok.com/*",
    "https://tiktok.com/*",
    "https://www.tiktok.com/*",
    "https://m.tiktok.com/*",
    "https://api.telegram.org/*",
    "https://generativelanguage.googleapis.com/*",
    "https://tikwm.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "https://*.trycloudflare.com/*",
    "https://drilling-beverly-reform-optimization.trycloudflare.com/*",
    "https://drilling-beverly-reform-optimization.trycloudflare.com/*",
    "https://drilling-beverly-reform-optimization.trycloudflare.com/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://seller-vn.tiktok.com/*",
        "https://seller.tiktok.com/*",
        "https://shop.tiktok.com/*",
        "https://ads.tiktok.com/*"
      ],
      "css": [
        "styles/style.css",
        "styles/strangetts-theme.css"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://m.tiktok.com/*"
      ],
      "js": [
        "src/tiktok_shop_video.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://m.tiktok.com/*"
      ],
      "js": [
        "vendor/strangetts_video/assets/hook-tiktok.ts-zORaIwzi.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://m.tiktok.com/*"
      ],
      "js": [
        "vendor/strangetts_video/assets/tiktok.ts-loader-B851c3SU.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/page_sniffer.js",
        "assets/logo.png",
        "assets/ads.png",
        "assets/noti.webp",
        "pages/dashboard.html",
        "pages/guide.html",
        "src/dashboard.js",
        "styles/dashboard.css",
        "styles/strangetts-theme.css",
        "pages/login.html",
        "src/login.js",
        "styles/login.css"
      ],
      "matches": [
        "https://seller-vn.tiktok.com/*",
        "https://seller.tiktok.com/*",
        "https://shop.tiktok.com/*",
        "https://ads.tiktok.com/*"
      ]
    },
    {
      "resources": [
        "vendor/strangetts_video/icons/product-bag.svg",
        "vendor/strangetts_video/assets/i18n-a5_SKMfx.js",
        "vendor/strangetts_video/assets/tiktok.ts-CBN9w_yp.js",
        "vendor/strangetts_video/assets/hook-tiktok.ts-zORaIwzi.js"
      ],
      "matches": [
        "https://www.tiktok.com/*",
        "https://m.tiktok.com/*"
      ],
      "use_dynamic_url": false
    }
  ]
}
