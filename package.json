{
  "name": "strange-tts-pc-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local desktop app shell for Strange TikTok Shop operations.",
  "scripts": {
    "start": "node scripts/start-pc-app.mjs",
    "app": "powershell -ExecutionPolicy Bypass -File scripts/open-desktop-app.ps1",
    "desktop": "powershell -ExecutionPolicy Bypass -File scripts/open-desktop-app.ps1",
    "pc:start": "node scripts/start-pc-app.mjs --launch",
    "stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-pc-app.ps1",
    "restart": "npm run stop && npm start",
    "desktop:shortcut": "powershell -ExecutionPolicy Bypass -File scripts/create-desktop-shortcut.ps1",
    "prod": "node scripts/start-pc-app.mjs --production",
    "build": "node scripts/build.mjs",
    "prod:smoke": "node scripts/smoke.mjs",
    "desktop:launch-smoke": "node scripts/desktop-launch-smoke.mjs",
    "test-matrix:smoke": "node scripts/test-matrix-smoke.mjs",
    "agent:wsl-runner-smoke": "node scripts/agent-wsl-run-smoke.mjs",
    "ui:shell-smoke": "node scripts/ui-shell-smoke.mjs",
    "crawler:contract-policy-smoke": "node scripts/crawler-contract-policy-smoke.mjs",
    "crawler:fixture-smoke": "node scripts/crawler-fixture-smoke.mjs",
    "cloud:local-smoke": "node scripts/cloud-sync-local-smoke.mjs",
    "gmv:max-smoke": "node scripts/gmv-max-dashboard-smoke.mjs",
    "shop:health-score-smoke": "node scripts/shop-health-score-smoke.mjs",
    "shop:violation-status-tags-smoke": "node scripts/shop-violation-status-tags-smoke.mjs",
    "shop:session-safety-smoke": "node scripts/shop-session-safety-smoke.mjs",
    "business:ads-spend-missing-smoke": "node scripts/ads-spend-missing-smoke.mjs",
    "business:legacy-xls-scope-smoke": "node scripts/legacy-xls-scope-smoke.mjs",
    "ops:daily-checklist-scope-smoke": "node scripts/daily-checklist-scope-smoke.mjs",
    "session:restore-gate-smoke": "node scripts/session-restore-gate-smoke.mjs",
    "video:safety-smoke": "node scripts/video-downloader-safety-smoke.mjs",
    "license:create": "node scripts/license-create.mjs",
    "security:scan": "node scripts/security-scan.mjs",
    "parity:audit": "node scripts/parity-audit.mjs",
    "data:migrate": "node scripts/migrate-cookie-store.mjs"
  },
  "engines": {
    "node": ">=22.12"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
